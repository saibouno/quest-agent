{
    "name":  "quest-agent",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Quest Agent v0.1 - turn ambitious goals into executable daily quests.",
    "scripts":  {
                    "dev":  "node --max-old-space-size=2048 ./node_modules/next/dist/bin/next dev",
                    "dev:inspect":  "node --inspect --max-old-space-size=2048 ./node_modules/next/dist/bin/next dev",
                    "build":  "next build",
                    "build:noprofile":  "cmd /d /s /c \"node scripts/build-noprofile.mjs\"",
                    "start":  "next start",
                    "lint":  "eslint . --max-warnings=0",
                    "typecheck":  "tsc --noEmit",
                    "guardrails":  "node scripts/ops-guardrails.mjs",
                    "harness:test:noprofile":  "cmd /d /s /c \"node --test --experimental-test-isolation=none tests/theme-harness.test.mjs tests/theme-ops.test.mjs tests/durable-context.test.mjs tests/dependency-guardrails.test.mjs\"",
                    "dogfood:backup:noprofile":  "cmd /d /s /c \"powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dogfood-backup.ps1\"",
                    "dogfood:restore:check:noprofile":  "cmd /d /s /c \"powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dogfood-restore-check.ps1\"",
                    "lint:noprofile":  "cmd /d /s /c \"node scripts/lint-noprofile.mjs\"",
                    "typecheck:noprofile":  "cmd /d /s /c \"node scripts/typecheck-noprofile.mjs\"",
                    "deps:guardrails:noprofile":  "cmd /d /s /c \"node scripts/dependency-guardrails.mjs\"",
                    "audit:runtime:noprofile":  "cmd /d /s /c \"npm.cmd audit --omit=dev --audit-level=high\"",
                    "verify:noprofile":  "cmd /d /s /c \"npm.cmd run lint:noprofile && npm.cmd run typecheck:noprofile && npm.cmd run guardrails:noprofile\"",
                    "security:verify:noprofile":  "cmd /d /s /c \"npm.cmd run deps:guardrails:noprofile && npm.cmd run verify:noprofile && npm.cmd run build:noprofile && npm.cmd run audit:runtime:noprofile\"",
                    "guardrails:noprofile":  "cmd /d /s /c \"node scripts/ops-guardrails.mjs\"",
                    "copy:audit":  "node scripts/copy-audit.mjs"
                },
    "keywords":  [
                     "nextjs",
                     "quest-agent",
                     "supabase"
                 ],
    "author":  "",
    "license":  "ISC",
    "dependencies":  {
                         "@supabase/supabase-js":  "^2.99.2",
                         "next":  "^16.2.2",
                         "react":  "^19.2.4",
                         "react-dom":  "^19.2.4",
                         "zod":  "^4.3.6"
                     },
    "overrides":  {
                      "flatted":  "3.4.2",
                      "minimatch@3.1.5":  {
                                                "brace-expansion":  "1.1.13"
                                            },
                      "minimatch@10.2.4":  {
                                                  "brace-expansion":  "5.0.5"
                                              },
                      "tinyglobby@0.2.15":  {
                                                 "picomatch":  "4.0.4"
                                             }
                  },
    "devDependencies":  {
                            "@types/node":  "^25.5.0",
                            "@types/react":  "^19.2.14",
                            "@types/react-dom":  "^19.2.3",
                            "eslint":  "^10.2.0",
                            "eslint-config-next":  "^16.2.2",
                            "supabase":  "^2.58.4",
                            "typescript":  "^5.9.3"
                        }
}
